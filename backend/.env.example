# ============================================
# Citi Bot QA Platform - Environment Variables
# ============================================

# LLM Configuration (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp

# LLM Evaluation Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Playwright Configuration
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=200
PLAYWRIGHT_TIMEOUT=60000

# Citi Credentials (optional)
# Leave both empty/commented for MANUAL LOGIN MODE - you'll enter credentials in browser
# Set both for AUTOMATED LOGIN MODE
# CITI_USER_ID=your_user_id
# CITI_PASSWORD=your_password

# Database
DATABASE_URL=sqlite:///./results.db

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
